# ---- Devin (v3 organization API) ----
# Service-user token starting with cog_ (app.devin.ai -> Settings -> API)
DEVIN_API_KEY=cog_xxx
# Your org id. Find it with:
#   curl -s https://api.devin.ai/v3/self -H "Authorization: Bearer $DEVIN_API_KEY"
DEVIN_ORG_ID=org-xxxx

# ---- Target repository ----
GITHUB_REPO=gabrycina/superset
GITHUB_BASE_BRANCH=master
# A token with repo scope (locally you can use:  gh auth token )
GITHUB_TOKEN=ghp_xxx
# Optional: HMAC secret shared with the GitHub webhook. Leave blank for local demo.
GITHUB_WEBHOOK_SECRET=
# Issues with this label are dispatched to Devin.
TRIGGER_LABEL=devin-fix

# ---- Runtime ----
POLL_INTERVAL_SECONDS=30
# Set to true to exercise the whole pipeline without spending any ACUs.
DRY_RUN=false

# ---- ROI model (dashboard only) ----
ENG_HOURS_PER_FINDING=2.5
ENG_HOURLY_COST=95
ACU_USD_COST=2.25
